#!/usr/bin/env node

var args = require('minimist')(process.argv.slice(2), {
    alias: {
        v: 'version'
      , h: 'help'
      , i: 'in'
      , o: 'out'
      , t: 'template'
      , d: 'data'
      , p: 'port'
      , m: 'mount'
    }
  , boolean: [ 'version', 'help' ]
  })
  , command = args._.slice(0)
  , Cli = require('../lib/codex/cli');

if (command.length === 0) {
  if (args.version) command.push('--version');
  else if (args.help) command.push('--help');
}

args.cwd = process.cwd();

Cli.emit(command, args);
